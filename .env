# Environment
NODE_ENV=development

# API
API_BASE_URL=http://localhost:3000
API_TIMEOUT=5000
API_KEY=mock-api-key

# Authentication
AUTH_USERNAME=admin
AUTH_PASSWORD=password
AUTH_STRATEGY=bearer

# Partner Integration
PARTNER_API_KEY=mock-partner-key

# Retry
RETRY_ATTEMPTS=1
RETRY_DELAY=500

# Logging
LOG_LEVEL=info

# Test
TEST_ENV=mock
